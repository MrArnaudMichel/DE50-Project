@startuml

skinparam packageStyle rectangle
top to bottom direction

package "core" {
  class Main {
    + {static} void main(String[])
  }

  class Logger {
    - {static} Logger instance
    - {static} boolean DEBUG
    - {static} String ANSI_RESET
    - {static} String ANSI_YELLOW
    - {static} String ANSI_RED
    + {static} Logger getInstance()
    + void log(String)
    + void warn(String)
    + void error(String)
    + void setDebug(Boolean)
  }

  class SVNPlugin {
    - Logger logger
    + void RhpPluginInit(IRPApplication)
    + void RhpPluginInvokeItem()
    + void OnMenuItemSelect(String)
    + void OnTrigger(String)
    + boolean RhpPluginCleanup()
    + void RhpPluginFinalCleanup()
  }
}

package "controller" {
  class Listener {
    - IRPApplication app
    - IRPProject project
    - Logger logger
    - ICalculationService calculationService
    - IRPDiagram diagram
    + boolean afterAddElement(IRPModelElement)
    + boolean onElementsChanged(String)
    + boolean afterProjectClose(String)
    + boolean beforeProjectClose(IRPProject)
    + String getId()
    + boolean onDiagramOpen(IRPDiagram)
    + boolean onDoubleClick(IRPModelElement)
    + boolean onFeaturesOpen(IRPModelElement)
  }
}

package "rhapsody" {
  class RhapsodyWrapper {
    + {static} boolean hasStereotype(IRPModelElement,String)
    + {static} void initTagIfAbsent(IRPModelElement,String,String)
    + {static} void initTagIfAbsent(IRPModelElement,String)
    + {static} void setOrCreateTag(IRPModelElement,String,String)
  }
}

package "constants" {
  class SVNConstants {
    + {static} String STEREOTYPE_STAKEHOLDER
    + {static} String STEREOTYPE_SYSTEM
    + {static} String STEREOTYPE_VALUE_ARC
    + {static} String STEREOTYPE_DIAGRAM
    + {static} String TAG_IMPORTANCE_SCORE
    + {static} String TAG_BENEFIT_RANKING
    + {static} String TAG_SUPPLY_IMPORTANCE
    + {static} String TAG_TOTAL_LOOP_SCORE
    + {static} String[] LITERALS_BENEFIT
    + {static} String[] LITERALS_SUPPLY
  }
}

package "model" {
  class ValueArc {
    - IRPDependency dependency
    + {static} double getArcScore(String,String)
    + IRPDependency getDependency()
    + double getScore()
    + void initDefaultTags()
    + {static} boolean isValueArc(IRPModelElement)
    + String getTagValue(String,String)
    + String getName()
    + String getGUID()
    + IRPModelElement getDependent()
    + IRPModelElement getDependsOn()
    + void setDisplayName(String)
    + void setIsShowDisplayName(int)
  }

  class Stakeholder {
    - IRPActor actor
    ~ double score
    + double getScore()
    + IRPActor getActor()
    + void setScore(double)
    + String getName()
    + String getGUID()
    + IRPTag getTag(String)
    + void setDisplayName(String)
    + IRPModelElement addNewAggr(String,String)
  }

  class SVNSystem {
    - IRPClass system
    - double totalLoopScore
    + IRPClass getSystem()
    + double getTotalLoopScore()
    + void setTotalLoopScore(double)
    + String getName()
    + String getGUID()
  }

  class ValueLoop {
    ~ List<String> nodes
    ~ List<Double> arcScores
    ~ double score
    + List<String> getNodes()
    + List<Double> getArcScores()
    + double getScore()
    + void setScore(double)
  }

  class SearchState {
    ~ String current
    ~ List<String> path
    ~ List<Double> scores
    ~ Set<String> visited
    + List<Double> getScores()
    + String getCurrent()
    + List<String> getPath()
    + Set<String> getVisited()
  }
}

package "service" {
  interface ICalculationService {
    ~ void calculateImportance(IRPDiagram)
  }

  interface ICalculationStrategy {
    ~ Map<Stakeholder,Double> computeScores(List<Stakeholder>,List<ValueArc>,SVNSystem)
  }

  package "impl" {
    class CalculationService {
      - Logger logger
      + void calculateImportance(IRPDiagram)
      - List<Stakeholder> findStakeholders(IRPDiagram)
      - List<ValueArc> findValueArcs(IRPDiagram)
      - SVNSystem findSystem(IRPDiagram)
    }

    class UpdateElementService {
      + {static} void updateArcLabel(ValueArc,IRPProject)
      + {static} void updateSystemTags(SVNSystem,double)
      + {static} void updateStakeholderImportance(Stakeholder,double)
    }
  }

  package "strategy" {
    class ArcSumStrategy {
      - Logger logger
      + Map<Stakeholder,Double> computeScores(List<Stakeholder>,List<ValueArc>,SVNSystem)
    }

    class ValueLoopStrategy {
      - Logger logger
      + Map<Stakeholder,Double> computeScores(List<Stakeholder>,List<ValueArc>,SVNSystem)
      - Map<String,List<ValueArc>> buildGraph(List<ValueArc>)
      - List<ValueLoop> findValueLoops(String,Map<String,List<ValueArc>>)
    }
  }
}

Main --> SVNPlugin

ICalculationStrategy <|.. ValueLoopStrategy
ICalculationStrategy <|.. ArcSumStrategy
ICalculationService <|.. CalculationService
RPApplicationListener <|-- Listener
RPUserPlugin <|-- SVNPlugin
RPUserPlugin <|-- SVNConstants

RhapsodyWrapper ..> IRPModelElement

Listener --> ICalculationService : calculationService
Listener ..> IRPDiagram
Listener ..> IRPProject
Listener ..> IRPApplication

CalculationService ..> Stakeholder
CalculationService ..> ValueArc
CalculationService ..> SVNSystem
CalculationService ..> IRPDiagram

ValueLoopStrategy ..> ValueLoop
ValueLoopStrategy ..> ValueArc
ValueLoopStrategy ..> Stakeholder
ValueLoopStrategy ..> SVNSystem

ArcSumStrategy ..> Stakeholder
ArcSumStrategy ..> ValueArc
ArcSumStrategy ..> SVNSystem

UpdateElementService ..> ValueArc
UpdateElementService ..> SVNSystem
UpdateElementService ..> Stakeholder
UpdateElementService ..> IRPProject

ValueArc --> IRPDependency : dependency
Stakeholder --> IRPActor : actor
SVNSystem --> IRPClass : system

SVNPlugin ..> Logger
Listener ..> Logger
CalculationService ..> Logger
ValueLoopStrategy ..> Logger
ArcSumStrategy ..> Logger

core -[hidden]r- controller
controller -[hidden]r- rhapsody
rhapsody -[hidden]r- constants
core -[hidden]d- model
model -[hidden]r- service

@enduml